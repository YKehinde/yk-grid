{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "outDir": "dist/server",
    "declaration": true,
    "declarationDir": "dist/server",
    "rootDir": "server",
    "composite": false
  },
  "include": ["server"],
  "exclude": ["node_modules", "dist"]
}
