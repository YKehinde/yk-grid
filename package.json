{
  "name": "yk-grid",
  "version": "1.0.0",
  "main": "dist/yk-grid.umd.js",
  "module": "dist/yk-grid.es.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "dev": "vite",
    "dev:example": "vite example --config vite.config.ts",
    "build": "tsc --noEmit && vite build && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Yemi Kehinde",
  "license": "MIT",
  "description": "Production-ready AI-assisted React DataGrid component",
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^27.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^3.2.6"
  }
}
